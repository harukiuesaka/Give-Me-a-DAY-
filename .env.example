# Give Me a DAY v1 - Environment Configuration
# Copy this file to .env and fill in values

# Data storage directory (relative to backend/)
DATA_DIR=./data

# Anthropic API key for LLM calls (optional: fallback templates used if empty)
ANTHROPIC_API_KEY=

# FRED API key for macro data (optional: macro data skipped if empty)
FRED_API_KEY=

# Timeout settings (seconds)
BACKTEST_TIMEOUT_SECONDS=300
PIPELINE_TIMEOUT_SECONDS=700

# Paper Run schedule (hour in JST, market close + 1hr)
PAPER_RUN_SCHEDULE_HOUR=16

# Default virtual capital for Paper Run
DEFAULT_VIRTUAL_CAPITAL=1000000

# Cost model (basis points)
DEFAULT_COMMISSION_BPS=10
DEFAULT_SPREAD_BPS=10
